// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  clerkUserId     String  @id
  firstName       String
  lastName        String?
  email           String @unique
  quizzes         Quiz[]
  attempts        Attempt[]
  profile         Profile?
}

model Profile{
  id      String @id @default(uuid())
  user    User @relation(fields: [userId],references: [clerkUserId])
  userId  String @unique
}

model Quiz{
  id          String  @id @default(uuid())
  title       String
  questions   Question[]
  createdBy   User    @relation(fields: [userId], references: [clerkUserId])
  userId      String
  totalTime   Int     @default(60)
  totalMarks  Decimal @default(100)
  createdAt   DateTime @default(now())
  attempts    Attempt[]
}

enum Status{
  ATTEMPTED
  NOT_ATTEMPTED
  FULLY_CHECKED
}

model Attempt{
  id              String  @id @default(uuid())
  quiz            Quiz    @relation(fields: [quizId],references: [id])
  quizId          String
  user            User    @relation(fields:[userId],references:[clerkUserId])
  userId          String
  marksObtained   Int?    @default(0)
  status          Status  @default(NOT_ATTEMPTED)
  answers         UserAnswer[]
  createdAt       DateTime @default(now())
}

model Question{
  id          String  @id @default(uuid())
  quiz        Quiz    @relation(fields: [quizId],references: [id])
  quizId      String
  type        Question_Type
  que         String
  marks       Decimal  @default(1)
  options     Option[]
  userAnswer  UserAnswer[] // array is used due to several attempts
}

enum Question_Type{
  SUBJECTIVE
  MCQ
}

model Option{
  id        String    @id @default(uuid())
  text      String
  question  Question  @relation(fields: [queId],references: [id])
  queId     String
  isCorrect Boolean    @default(false)
  answers   UserAnswer[] // array for different attempts
}

model UserAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id])
  queId      String
  que        Question @relation(fields:[queId], references:[id])
  optionId   String?   @unique
  option     Option?   @relation(fields:[optionId], references:[id])
  answerText String?
  @@unique([attemptId,queId])
}


